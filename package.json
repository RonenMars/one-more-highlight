{
  "name": "one-more-highlight",
  "version": "0.5.0",
  "description": "Multi-state substring highlighting for React. Highlight every match in one style, plus specific occurrences (by index, range, or list) in another.",
  "keywords": [
    "react",
    "highlight",
    "highlighter",
    "search",
    "substring",
    "mark",
    "typescript",
    "multi-state",
    "react-highlight",
    "react-highlight-words"
  ],
  "homepage": "https://one-more-highlight.vercel.app",
  "bugs": {
    "url": "https://github.com/RonenMars/one-more-highlight/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RonenMars/one-more-highlight.git"
  },
  "license": "MIT",
  "author": "Ronen Mars",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test --config tests/visual/playwright.config.ts",
    "test:visual:update": "playwright test --config tests/visual/playwright.config.ts --update-snapshots",
    "test:visual:ui": "playwright test --config tests/visual/playwright.config.ts --ui",
    "lint:pkg": "publint && attw --pack .",
    "size": "size-limit",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm lint:pkg && pnpm size",
    "prepare": "husky",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "release": "semantic-release"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "escape-string-regexp": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.18.2",
    "commitlint": "^19.6.1",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fast-check": "^3.23.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.4.3",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semantic-release": "^24.2.3",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "size-limit": [
    {
      "name": "ESM (full)",
      "path": "dist/index.js",
      "limit": "3 KB"
    },
    {
      "name": "CJS (full)",
      "path": "dist/index.cjs",
      "limit": "3 KB"
    }
  ],
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint"
    ]
  }
}
